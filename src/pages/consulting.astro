---
import Layout from "../layouts/Layout.astro";
import background from "../assets/background.jpg";
import photo from "../assets/photo.jpeg";
---

<Layout
  title="Groundwork Technical Solutions | Ebony Hargro"
  description="Technical curriculum design, developer education, and project management consulting for non-profits and mission-driven organizations. Groundwork Technical Solutions, founded by Ebony Hargro."
>
  <div id="page">
    <img id="background" src={background.src} alt="" fetchpriority="high" />

    <!-- Nav -->
    <nav>
      <a href="/" class="nav-back">← ebonyhargro.com</a>
      <span class="nav-title">Consulting</span>
    </nav>

    <!-- Hero -->
    <section id="hero">
      <!-- Subtle botanical accent -->
      <svg class="botanical" viewBox="0 0 120 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M60 155 C60 155 60 80 60 20" stroke="#7A9E7E" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M60 110 C60 110 30 95 18 72" stroke="#7A9E7E" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M60 90 C60 90 88 75 98 54" stroke="#7A9E7E" stroke-width="1.2" stroke-linecap="round"/>
        <path d="M60 130 C60 130 40 122 32 108" stroke="#A8C4A2" stroke-width="1" stroke-linecap="round"/>
        <path d="M60 70 C60 70 78 58 84 42" stroke="#A8C4A2" stroke-width="1" stroke-linecap="round"/>
        <!-- Leaf at top -->
        <ellipse cx="60" cy="18" rx="6" ry="10" fill="#7A9E7E" opacity="0.5" transform="rotate(-8 60 18)"/>
        <!-- Leaves on branches -->
        <ellipse cx="19" cy="70" rx="10" ry="6" fill="#7A9E7E" opacity="0.35" transform="rotate(-35 19 70)"/>
        <ellipse cx="97" cy="52" rx="10" ry="6" fill="#7A9E7E" opacity="0.35" transform="rotate(30 97 52)"/>
        <ellipse cx="32" cy="106" rx="8" ry="5" fill="#A8C4A2" opacity="0.3" transform="rotate(-25 32 106)"/>
        <ellipse cx="84" cy="40" rx="8" ry="5" fill="#A8C4A2" opacity="0.3" transform="rotate(20 84 40)"/>
      </svg>

      <p class="eyebrow">Groundwork Technical Solutions</p>
      <h1>Building The Next Generation of Technical Talent.</h1>
      <p class="subhead">
        We partner with non-profits, startups, and mission-driven organizations to design
        and deliver technical education programs that build career-ready
        engineers.
      </p>
      <a href="#contact" class="cta-button">Schedule a Discovery Call →</a>
    </section>

    <!-- The Problem -->
    <section class="section" id="problem">
      <div class="glass-card">
        <p class="section-label">The Problem</p>
        <h2>Most technical education programs are outdated and inaccessible.</h2>
        <p class="body-text">
          Organizations launch technical training programs with the right intentions —
          but without the engineering expertise to build curriculum that actually prepares
          learners for the job. The result: graduates who complete the program but can't
          pass a technical interview, and organizations that want talented junior engineers but can't figure out where to find them.
        </p>
        <p class="body-text">Groundwork Technical Solutions fixes that.</p>
      </div>
    </section>

    <!-- Services -->
    <section class="section" id="services">
      <p class="section-label">Services</p>
      <h2 class="section-title">Expert consulting. Real results.</h2>
      <div class="services-grid">

        <div class="service-card">
          <div class="service-number">01</div>
          <h3>Curriculum Design &amp; Development</h3>
          <p>Full technical training programs built from scratch — learning objectives, lesson plans, coding labs, project-based assessments, and instructor guides. Aligned to real industry standards.</p>
        </div>

        <div class="service-card">
          <div class="service-number">02</div>
          <h3>Program Audit &amp; Improvement Roadmap</h3>
          <p>An expert review of your existing program with a clear diagnosis of what isn't working and a prioritized roadmap to fix it. Written report with actionable recommendations.</p>
        </div>

        <div class="service-card">
          <div class="service-number">03</div>
          <h3>Technical Workshop Delivery</h3>
          <p>Live, hands-on instruction for your cohort or team. Topics include full-stack development, React &amp; Node.js, API design, and technical interview prep. Available virtually or on-site.</p>
        </div>

        <div class="service-card">
          <div class="service-number">04</div>
          <h3>Fractional Technical Education Lead</h3>
          <p>Ongoing advisory as your part-time technical education director. Curriculum oversight, instructor hiring input, program strategy. 8–20 hours/month, 3-month minimum.</p>
        </div>

        <div class="service-card">
          <div class="service-number">05</div>
          <h3>Technical Project Management &amp; Documentation</h3>
          <p>End-to-end management of technical projects — scope definition, requirements documentation, delivery planning, and stakeholder communication. Ideal for teams that need an experienced technical PM without the full-time hire.</p>
        </div>

      </div>
    </section>

    <!-- About -->
    <section class="section" id="about">
      <div class="about-grid">
        <div class="about-photo-col">
          <img src={photo.src} alt="Photo of Ebony Hargro" class="about-photo" />
        </div>
        <div class="about-text-col">
          <p class="section-label">Meet the Team</p>
          <h2>Built from the ground up.</h2>
          <p class="body-text">
            I'm Ebony Hargro — a software engineer, technical educator, and curriculum
            designer with over a decade at the intersection of engineering, teaching, community advocacy, and product.
          </p>
          <p class="body-text">
            I've built production features at Intuit QuickBooks that touched millions
            of users. I've led cross-functional teams from kickoff to launch. I've stood
            in front of cohorts of emerging engineers and taught them how to build
            full-stack applications from scratch at CodePath's Meta U partnership program. I've also nurtured communities as a developer advocate at GCode, and helped interview and select candidates for CodePath's Futureforce Tech Launchpad program.
          </p>
          <p class="body-text">
            That combination — real engineering experience plus the ability to teach it —
            is what makes the difference between a
            curriculum that looks good on paper and one that actually prepares learners
            for success.
          </p>
          <div class="credentials">
            <span class="credential">Software Engineer — Intuit QuickBooks</span>
            <span class="credential">Lead Instructor, Interviewer, & Consultant — CodePath</span>
            <span class="credential">Senior PM — Datos Insights</span>
            <span class="credential">B.A. — Duke University</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Process -->
    <section class="section" id="process">
      <p class="section-label">How It Works</p>
      <h2 class="section-title">A process built for organizations with real goals.</h2>
      <div class="steps-grid">
        <div class="step">
          <div class="step-num">1</div>
          <div>
            <h4>Discovery Call</h4>
            <p>30 minutes, free. We talk about where your program is and where you want it to go. No pitch, no pressure.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div>
            <h4>Proposal & Scope</h4>
            <p>Within one week you'll receive a clear, fixed-fee proposal with deliverables, timeline, and pricing. No ambiguity.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div>
            <h4>Build & Iterate</h4>
            <p>We do the work. You receive regular updates and review checkpoints. No disappearing acts.</p>
          </div>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <div>
            <h4>Delivery & Handoff</h4>
            <p>A fully documented, ready-to-use deliverable — with a full walkthrough so your team can run it confidently.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="section" id="contact">
      <div class="glass-card contact-card">
        <p class="section-label">Get in Touch</p>
        <h2>Let's build the program your learners deserve.</h2>
        <p class="body-text">
          Whether you're launching something new, improving what you have, or not sure
          where to start — reach out. The discovery call is free and there's no obligation.
        </p>
        <a href="mailto:ebonyhargro@gmail.com" class="cta-button">
          Email Us →
        </a>
        <p class="response-note">We respond to all inquiries within 2 business days.</p>
      </div>
    </section>

    <footer>
      <a href="/" class="footer-back">← Back to ebonyhargro.com</a>
      <span class="footer-copy">© 2026 Ebony Hargro · Groundwork Technical Solutions</span>
    </footer>

  </div>
</Layout>

<style>
  /* ── Reset & base ──────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  /* Earthy warm background overlay */
  #page::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(245, 240, 228, 0.38);
    z-index: -1;
    pointer-events: none;
  }

  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    filter: blur(100px) saturate(0.9);
    object-fit: cover;
  }

  #page {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Arial, sans-serif;
    color: #1c2b20;
    min-height: 100vh;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Nav ───────────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(61, 107, 79, 0.12);
  }

  .nav-back {
    font-size: 13px;
    color: #6b7c6e;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 150ms ease;
  }
  .nav-back:hover { color: #1c2b20; }

  .nav-title {
    font-size: 13px;
    font-weight: 600;
    color: #1c2b20;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── Botanical SVG ─────────────────────────────────── */
  .botanical {
    position: absolute;
    right: -20px;
    top: 20px;
    width: 90px;
    height: 120px;
    opacity: 0.55;
    pointer-events: none;
  }

  /* ── Glass card ────────────────────────────────────── */
  .glass-card {
    background: rgba(245, 241, 232, 0.70);
    border: 1px solid rgba(61, 107, 79, 0.11);
    border-radius: 20px;
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    box-shadow:
      0 4px 24px rgba(40, 70, 50, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    padding: 2.5rem 2.5rem 2rem;
  }

  /* ── Hero ──────────────────────────────────────────── */
  #hero {
    position: relative;
    padding: 5rem 0 3.5rem;
    max-width: 680px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5c8c6e;
    margin: 0 0 1rem;
  }

  #hero h1 {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #1a2e1f;
    margin: 0 0 1.25rem;
  }

  .subhead {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    line-height: 1.65;
    color: #3d5244;
    max-width: 560px;
    margin: 0 0 2rem;
  }

  /* ── CTA button ────────────────────────────────────── */
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    background: #2d4a3e;
    border: none;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(40, 70, 50, 0.30);
    transition:
      background 160ms ease,
      box-shadow 200ms ease,
      transform 120ms ease;
  }

  .cta-button:hover {
    background: #3d6b4f;
    box-shadow: 0 8px 24px rgba(40, 70, 50, 0.40);
    transform: translateY(-1px);
  }

  .cta-button:active { transform: scale(0.98); }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding: 4rem 0;
    border-top: 1px solid rgba(61, 107, 79, 0.09);
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7a9e7e;
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1a2e1f;
    margin: 0 0 2.5rem;
    line-height: 1.2;
  }

  h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1a2e1f;
    margin: 0 0 1.25rem;
    line-height: 1.25;
  }

  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #3d5244;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  /* ── Services grid ─────────────────────────────────── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .service-card {
    background: rgba(245, 241, 232, 0.68);
    border: 1px solid rgba(61, 107, 79, 0.11);
    border-radius: 16px;
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    box-shadow:
      0 2px 12px rgba(40, 70, 50, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 200ms ease, transform 180ms ease;
  }

  .service-card:hover {
    box-shadow:
      0 8px 28px rgba(40, 70, 50, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.68);
    transform: translateY(-2px);
  }

  .service-number {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #7a9e7e;
    font-variant-numeric: tabular-nums;
  }

  .service-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a2e1f;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .service-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #4a6354;
    margin: 0;
  }

  .service-price {
    font-size: 0.85rem !important;
    font-weight: 600 !important;
    color: #5c8c6e !important;
    padding-top: 0.25rem;
    border-top: 1px solid rgba(61, 107, 79, 0.10);
    margin-top: auto !important;
  }

  /* ── About ─────────────────────────────────────────── */
  .about-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: start;
  }

  .about-photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(255, 255, 255, 0.9);
    box-shadow: 0 8px 28px rgba(40, 70, 50, 0.15);
    flex-shrink: 0;
  }

  .credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .credential {
    font-size: 12px;
    color: #5c7a62;
    background: rgba(235, 242, 232, 0.75);
    border: 1px solid rgba(61, 107, 79, 0.14);
    border-radius: 999px;
    padding: 4px 12px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  /* ── Process steps ─────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 1.25rem;
  }

  .step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #2d4a3e;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .step h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a2e1f;
    margin: 0 0 0.35rem;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #4a6354;
    margin: 0;
  }

  /* ── Contact ───────────────────────────────────────── */
  .contact-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .contact-card h2 { text-align: center; }
  .contact-card .body-text { text-align: center; }

  .response-note {
    font-size: 12px;
    color: #7a9e7e;
    margin: 0;
  }

  /* ── Footer ────────────────────────────────────────── */
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 0;
    border-top: 1px solid rgba(61, 107, 79, 0.09);
    margin-top: 1rem;
  }

  .footer-back {
    font-size: 13px;
    color: #7a9e7e;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-back:hover { color: #1c2b20; }

  .footer-copy {
    font-size: 12px;
    color: #a8c4a2;
  }

  /* ── Responsive ────────────────────────────────────── */
  @media (max-width: 600px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .about-photo-col { display: flex; justify-content: center; }
    .about-photo { width: 100px; height: 100px; }

    .glass-card { padding: 1.75rem 1.5rem; }

    #hero { padding: 3rem 0 2.5rem; }

    .botanical { width: 60px; height: 80px; right: -8px; top: 16px; }
  }
</style>
