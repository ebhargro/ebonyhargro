---
import Layout from "../layouts/Layout.astro";
import background from "../assets/background.jpg";
---

<Layout
  title="Engineering | Ebony Hargro"
  description="Software engineer portfolio — coming soon."
>
  <div id="page">
    <img id="background" src={background.src} alt="" fetchpriority="high" />
    <nav>
      <a href="/" class="nav-back">← home</a>
    </nav>
    <section id="hero">
      <p class="eyebrow">Engineering</p>
      <h1>Something's coming.</h1>
      <p class="subhead">This page is under construction. Check back soon.</p>
      <a href="/" class="back-link">← Back to home</a>
    </section>
  </div>
</Layout>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(100px);
    object-fit: cover;
  }

  #page {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Arial, sans-serif;
    color: #1a2e1f;
    min-height: 100vh;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  nav {
    display: flex;
    align-items: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(45, 74, 62, 0.10);
  }

  .nav-back {
    font-size: 13px;
    color: #7a9e7e;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .nav-back:hover { color: #1a2e1f; }

  #hero {
    padding: 6rem 0 3rem;
    max-width: 560px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7a9e7e;
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2rem, 5.5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: #1a2e1f;
    margin: 0 0 1.25rem;
    line-height: 1.12;
  }

  .subhead {
    font-size: 1.05rem;
    line-height: 1.65;
    color: #3d5244;
    margin: 0 0 2rem;
  }

  .back-link {
    font-size: 14px;
    font-weight: 500;
    color: #2d4a3e;
    text-decoration: none;
    border-bottom: 1px solid rgba(45, 74, 62, 0.3);
    padding-bottom: 1px;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .back-link:hover {
    color: #1a2e1f;
    border-bottom-color: #1a2e1f;
  }
</style>
