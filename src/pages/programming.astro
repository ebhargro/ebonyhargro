---
import Layout from "../layouts/Layout.astro";
import background from "../assets/background.jpg";
---

<Layout
  title="Builder | Ebony Hargro"
  description="things I build — creative tools, full-stack apps, and AI-powered experiences."
>
  <div id="page">
    <img id="background" src={background.src} alt="" fetchpriority="high" />

    <!-- Nav -->
    <nav>
      <a href="/" class="nav-back">&larr; ebonyhargro.com</a>
      <span class="nav-title">Builder</span>
    </nav>

    <!-- Hero -->
    <section id="hero">
      <p class="eyebrow">Engineering &amp; Product</p>
      <h1>I build projects close to my heart.</h1>
      <p class="subhead">
        I looovee education and storytelling!
        Here's a look at what I've been building.
      </p>
    </section>

    <!-- Featured Project: Wordplay -->
    <section class="section" id="featured">
      <p class="section-label">Featured Project</p>
      <h2 class="section-title">wordplay</h2>
      <p class="body-text">
        A creative writing exercise generator powered by AI. Pick your story parameters &mdash;
        length, point of view, setting, tone, and pacing &mdash; and Wordplay crafts a
        unique writing prompt to spark your next story.
      </p>

      <div class="tech-tags">
        <span class="tech-tag">Next.js</span>
        <span class="tech-tag">React</span>
        <span class="tech-tag">React Native</span>
        <span class="tech-tag">OpenAI</span>
        <span class="tech-tag">Supabase</span>
        <span class="tech-tag">TypeScript</span>
      </div>

      <!-- Live Demo Embed -->
      <div class="demo-container">
        <div class="demo-header">
          <div class="demo-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="demo-label">Live Demo</span>
          <a
            href="https://wordplay-app.vercel.app"
            target="_blank"
            rel="noopener noreferrer"
            class="demo-external"
          >
            Open in new tab &nearr;
          </a>
        </div>
        <div class="demo-frame-wrapper">
          <iframe
            src="https://wordplay-app.vercel.app"
            title="Wordplay - Live Demo"
            class="demo-frame"
            loading="lazy"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
          ></iframe>
          <div class="demo-overlay" id="demoOverlay">
            <button class="demo-activate-btn" id="demoActivateBtn">
              Click to interact with demo
            </button>
          </div>
        </div>
      </div>

      <div class="project-links">
        <a
          href="https://wordplay-app.vercel.app"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-button"
        >
          Try Wordplay &rarr;
        </a>
        <a
          href="https://github.com/ebhargro/wordplay"
          target="_blank"
          rel="noopener noreferrer"
          class="source-link"
        >
          View Source on GitHub
        </a>
      </div>
    </section>

    <!-- More Projects -->
    <section class="section" id="projects">
      <p class="section-label">More Work</p>
      <h2 class="section-title">Other things I've built.</h2>
      <div class="projects-grid">

        <div class="project-card">
          <div class="project-number">01</div>
          <h3>Wordplay (iOS)</h3>
          <p>
            The mobile companion to Wordplay, built with React Native and Expo.
            Same creative writing experience, native on your phone.
          </p>
          <div class="card-tags">
            <span class="card-tag">React Native</span>
            <span class="card-tag">Expo</span>
            <span class="card-tag">iOS</span>
          </div>
          <span class="project-status">Coming to App Store</span>
        </div>

        <div class="project-card empty-card">
          <div class="project-number">02</div>
          <h3>More coming soon</h3>
          <p>
            I'm always building something new. Check back for more projects, or reach out
            if you'd like to collaborate.
          </p>
        </div>

      </div>
    </section>

    <!-- Contact -->
    <section class="section" id="contact">
      <div class="glass-card contact-card">
        <p class="section-label">Get In Touch</p>
        <h2>Want to work together?</h2>
        <p class="body-text">
          Whether it's a collaboration, a contract role, or just to chat about building things &mdash;
          I'd love to hear from you.
        </p>
        <a href="mailto:ebonyhargro@gmail.com" class="cta-button">Say hello &rarr;</a>
      </div>
    </section>

    <footer>
      <a href="/" class="footer-back">&larr; Back to ebonyhargro.com</a>
      <span class="footer-copy">&copy; 2026 Ebony Hargro</span>
    </footer>
  </div>
</Layout>

<script>
  const overlay = document.getElementById('demoOverlay');
  const btn = document.getElementById('demoActivateBtn');
  if (overlay && btn) {
    btn.addEventListener('click', () => {
      overlay.style.display = 'none';
    });
  }
</script>

<style>
  /* ── Reset & base ──────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }

  #page::before {
    content: '';
    position: fixed;
    inset: 0;
    background: rgba(245, 240, 228, 0.38);
    z-index: -1;
    pointer-events: none;
  }

  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    filter: blur(100px) saturate(0.9);
    object-fit: cover;
  }

  #page {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Arial, sans-serif;
    color: #1c2b20;
    min-height: 100vh;
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Nav ───────────────────────────────────────────── */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(61, 107, 79, 0.12);
  }

  .nav-back {
    font-size: 13px;
    color: #6b7c6e;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: color 150ms ease;
  }
  .nav-back:hover { color: #1c2b20; }

  .nav-title {
    font-size: 13px;
    font-weight: 600;
    color: #1c2b20;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ── Hero ──────────────────────────────────────────── */
  #hero {
    position: relative;
    padding: 5rem 0 3.5rem;
    max-width: 680px;
  }

  .eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5c8c6e;
    margin: 0 0 1rem;
  }

  #hero h1 {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #1a2e1f;
    margin: 0 0 1.25rem;
  }

  .subhead {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    line-height: 1.65;
    color: #3d5244;
    max-width: 560px;
    margin: 0;
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding: 4rem 0;
    border-top: 1px solid rgba(61, 107, 79, 0.09);
  }

  .section-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7a9e7e;
    margin: 0 0 0.75rem;
  }

  .section-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1a2e1f;
    margin: 0 0 2.5rem;
    line-height: 1.2;
  }

  h2 {
    font-size: clamp(1.4rem, 3vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: #1a2e1f;
    margin: 0 0 1.25rem;
    line-height: 1.25;
  }

  .body-text {
    font-size: 1rem;
    line-height: 1.7;
    color: #3d5244;
    margin: 0 0 1rem;
    max-width: 640px;
  }

  /* ── Tech tags ──────────────────────────────────────── */
  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0 2rem;
  }

  .tech-tag {
    font-size: 12px;
    color: #5c7a62;
    background: rgba(235, 242, 232, 0.75);
    border: 1px solid rgba(61, 107, 79, 0.14);
    border-radius: 999px;
    padding: 4px 12px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    font-weight: 500;
  }

  /* ── Demo embed ─────────────────────────────────────── */
  .demo-container {
    background: rgba(245, 241, 232, 0.70);
    border: 1px solid rgba(61, 107, 79, 0.11);
    border-radius: 16px;
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    box-shadow:
      0 4px 24px rgba(40, 70, 50, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .demo-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(61, 107, 79, 0.09);
  }

  .demo-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green { background: #28c840; }

  .demo-label {
    font-size: 12px;
    font-weight: 600;
    color: #7a9e7e;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    flex: 1;
  }

  .demo-external {
    font-size: 12px;
    color: #7a9e7e;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .demo-external:hover { color: #1c2b20; }

  .demo-frame-wrapper {
    position: relative;
    width: 100%;
    height: 520px;
  }

  .demo-frame {
    width: 100%;
    height: 100%;
    border: none;
    background: #fff;
  }

  .demo-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(26, 46, 31, 0.04);
    cursor: pointer;
    transition: background 200ms ease;
  }

  .demo-overlay:hover {
    background: rgba(26, 46, 31, 0.08);
  }

  .demo-activate-btn {
    padding: 12px 28px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    color: #fff;
    background: rgba(45, 74, 62, 0.85);
    border: none;
    cursor: pointer;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 4px 16px rgba(40, 70, 50, 0.25);
    transition: background 160ms ease, transform 120ms ease;
  }
  .demo-activate-btn:hover {
    background: rgba(45, 74, 62, 0.95);
    transform: translateY(-1px);
  }

  /* ── Project links ──────────────────────────────────── */
  .project-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 24px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #fff;
    background: #2d4a3e;
    border: none;
    text-decoration: none;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(40, 70, 50, 0.30);
    transition:
      background 160ms ease,
      box-shadow 200ms ease,
      transform 120ms ease;
  }
  .cta-button:hover {
    background: #3d6b4f;
    box-shadow: 0 8px 24px rgba(40, 70, 50, 0.40);
    transform: translateY(-1px);
  }
  .cta-button:active { transform: scale(0.98); }

  .source-link {
    font-size: 14px;
    font-weight: 500;
    color: #2d4a3e;
    text-decoration: none;
    border-bottom: 1px solid rgba(45, 74, 62, 0.3);
    padding-bottom: 1px;
    transition: border-color 150ms ease, color 150ms ease;
  }
  .source-link:hover {
    color: #1a2e1f;
    border-bottom-color: #1a2e1f;
  }

  /* ── Projects grid ──────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    background: rgba(245, 241, 232, 0.68);
    border: 1px solid rgba(61, 107, 79, 0.11);
    border-radius: 16px;
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    box-shadow:
      0 2px 12px rgba(40, 70, 50, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.6);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 200ms ease, transform 180ms ease;
  }

  .project-card:hover {
    box-shadow:
      0 8px 28px rgba(40, 70, 50, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.68);
    transform: translateY(-2px);
  }

  .project-number {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: #7a9e7e;
    font-variant-numeric: tabular-nums;
  }

  .project-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #1a2e1f;
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .project-card p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #4a6354;
    margin: 0;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .card-tag {
    font-size: 11px;
    color: #5c7a62;
    background: rgba(235, 242, 232, 0.6);
    border: 1px solid rgba(61, 107, 79, 0.1);
    border-radius: 999px;
    padding: 2px 9px;
  }

  .project-status {
    font-size: 0.8rem;
    font-weight: 600;
    color: #5c8c6e;
    padding-top: 0.25rem;
    border-top: 1px solid rgba(61, 107, 79, 0.10);
    margin-top: auto;
  }

  .empty-card {
    border-style: dashed;
    opacity: 0.7;
  }

  /* ── Glass card ─────────────────────────────────────── */
  .glass-card {
    background: rgba(245, 241, 232, 0.70);
    border: 1px solid rgba(61, 107, 79, 0.11);
    border-radius: 20px;
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    box-shadow:
      0 4px 24px rgba(40, 70, 50, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.65);
    padding: 2.5rem 2.5rem 2rem;
  }

  .contact-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .contact-card h2 { text-align: center; }
  .contact-card .body-text { text-align: center; }

  /* ── Footer ─────────────────────────────────────────── */
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 2rem 0;
    border-top: 1px solid rgba(61, 107, 79, 0.09);
    margin-top: 1rem;
  }

  .footer-back {
    font-size: 13px;
    color: #7a9e7e;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-back:hover { color: #1c2b20; }

  .footer-copy {
    font-size: 12px;
    color: #a8c4a2;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media (max-width: 600px) {
    .glass-card { padding: 1.75rem 1.5rem; }
    #hero { padding: 3rem 0 2.5rem; }
    .demo-frame-wrapper { height: 400px; }
    .project-links { flex-direction: column; align-items: flex-start; }
  }
</style>
