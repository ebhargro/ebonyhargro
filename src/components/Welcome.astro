---
import background from "../assets/background.jpg";
import photo from "../assets/photo.jpeg";
import ActionButton from "./ActionButton.jsx";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <section id="hero">
      <a href="https://www.linkedin.com/in/ebonyhargro" target="_blank" rel="noopener">
        <img src={photo.src} alt="Photo of Ebony Hargro" class="photo-button" />
      </a>

      <h1>hi, I'm <a href="https://www.linkedin.com/in/ebonyhargro" target="_blank" rel="noopener" class="name-link">Ebony</a>.</h1>
      <h2>check out my work.</h2>

      <section class="button-container">
        <div class="page-button" style="--angle: 210deg">
          <div class="page-button__inner">
            <ActionButton client:load label="builder" href="/programming" />
          </div>
        </div>
        <div class="page-button" style="--angle: 330deg">
          <div class="page-button__inner">
            <ActionButton client:load label="consultant" href="/consulting" />
          </div>
        </div>
      </section>
    </section>
  </main>
</div>

<style>
  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    filter: blur(100px);
  }

  #container {
    font-family: Inter, system-ui, Arial, sans-serif;
    min-height: 100vh;
  }

  main {
    min-height: 100svh;
    display: grid;
    place-items: center;
  }

  #hero {
    --photo: clamp(80px, 40vw, 180px);
    --btn-h: 54px;
    --gap: 26px;
    position: relative;
    aspect-ratio: 1;
    margin: 2rem auto;
    display: grid;
    place-items: center;
    --photo-b: 0.1px;
  }

  .photo-button {
    width: var(--photo);
    height: var(--photo);
    border-radius: 50%;
    border: 2px solid white;
    object-fit: cover;
    display: block;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .photo-button:hover {
    transform: scale(1.04);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.22);
  }

  h1 {
    font-size: 22px;
    margin: 0.25em 0 0;
    color: #1a2e1f;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .name-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1.5px solid rgba(45, 74, 62, 0.35);
    padding-bottom: 1px;
    transition: border-color 150ms ease, color 150ms ease;
  }

  .name-link:hover {
    color: #2d4a3e;
    border-bottom-color: #2d4a3e;
  }

  h2 {
    color: #3d5244;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .button-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .page-button {
    position: absolute;
    left: 50%;
    top: 50%;
    height: var(--btn-h);
    transform: translate(-50%, -50%) rotate(var(--angle, 0deg))
      translateX(
        calc(
          (var(--photo) / 2) + var(--photo-b, 0px) + (var(--btn-h) / 2) +
            var(--gap)
        )
      );
    transform-origin: center;
    pointer-events: auto;
  }

  .page-button__inner {
    display: inline-flex;
    align-items: center;
    height: var(--btn-h);
    transform: rotate(90deg);
    transform-origin: center;
  }

  /* ── Mobile ──────────────────────────────────────────── */
  @media (max-width: 520px) {
    #hero {
      aspect-ratio: auto;
      padding-bottom: 1rem;
    }
    .button-container {
      position: static;
      display: grid;
      gap: 10px;
      justify-items: center;
      margin-top: 1rem;
    }
    .page-button,
    .page-button__inner {
      transform: none;
      position: static;
    }
  }
</style>
