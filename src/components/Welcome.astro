---
import background from "../assets/background.jpg";
import photo from "../assets/photo.jpeg";
import ActionButton from "./ActionButton.jsx";
---

<div id="container">
  <img id="background" src={background.src} alt="" fetchpriority="high" />
  <main>
    <section id="hero">
      <a href="https://www.linkedin.com/in/ebonyhargro" target="_blank" rel="noopener">
        <img src={photo.src} alt="Photo of Ebony Hargro" class="photo-button" />
      </a>

      <h1>hi, I'm <a href="https://www.linkedin.com/in/ebonyhargro" target="_blank" rel="noopener" class="name-link">Ebony</a>.</h1>
      <h2>check out my work.</h2>

      <div class="button-row">
        <ActionButton client:load label="builder" href="/programming" />
        <ActionButton client:load label="consultant" href="/consulting" />
      </div>
    </section>
  </main>
</div>

<style>
  #background {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    filter: blur(80px) saturate(1.2);
    object-fit: cover;
  }

  /* Soft vignette pulls focus to center */
  #container::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background: radial-gradient(
      ellipse 70% 70% at 50% 48%,
      transparent 30%,
      rgba(0, 0, 0, 0.08) 100%
    );
    pointer-events: none;
  }

  #container {
    font-family: Inter, system-ui, Arial, sans-serif;
    min-height: 100vh;
  }

  main {
    min-height: 100svh;
    display: grid;
    place-items: center;
  }

  #hero {
    --photo: clamp(80px, 40vw, 180px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-align: center;
    margin: 2rem auto;
  }

  .photo-button {
    width: var(--photo);
    height: var(--photo);
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.96);
    object-fit: cover;
    display: block;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.30),
      0 8px 24px rgba(0, 0, 0, 0.18),
      0 24px 56px rgba(0, 0, 0, 0.12);
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .photo-button:hover {
    transform: scale(1.03);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.40),
      0 12px 32px rgba(0, 0, 0, 0.24),
      0 32px 72px rgba(0, 0, 0, 0.14);
  }

  h1 {
    font-size: 22px;
    margin: 0.6em 0 0;
    color: #1a2e1f;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .name-link {
    color: inherit;
    text-decoration: none;
    border-bottom: 1.5px solid rgba(45, 74, 62, 0.35);
    padding-bottom: 1px;
    transition: border-color 150ms ease, color 150ms ease;
  }

  .name-link:hover {
    color: #2d4a3e;
    border-bottom-color: #2d4a3e;
  }

  h2 {
    color: #3d5244;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0.3em 0 0;
  }

  .button-row {
    display: flex;
    gap: 12px;
    margin-top: 1.5rem;
    justify-content: center;
  }
</style>
